rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Security rules for AfriVerify Hub
    // Rules updated to ensure authenticated access to core collections

    // Allow authenticated users to manage verification records
    match /verifications/{verificationId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to manage attendance logs
    match /attendance/{attendanceId} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to submit enterprise leads (write-only for security)
    match /leads/{leadId} {
      allow create: if request.auth != null;
      allow read: if false; 
    }
    
    // Global deny for unspecified paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}