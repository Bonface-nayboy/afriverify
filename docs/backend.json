
{
  "entities": {
    "Verification": {
      "title": "Verification",
      "description": "A record of an identity verification attempt (KYC).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "ocrData": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "idNumber": { "type": "string" },
            "dob": { "type": "string" },
            "expiry": { "type": "string" },
            "documentType": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "faceMatchScore": { "type": "number" },
        "livenessScore": { "type": "number" },
        "riskScore": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "status": { "type": "string", "enum": ["VERIFIED", "SUSPICIOUS", "FAILED"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "aiExplanation": { "type": "string" }
      },
      "required": ["ocrData", "status", "timestamp", "companyId"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "A record of a successful facial recognition check-in.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "userName": { "type": "string" },
        "confidence": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } }
      },
      "required": ["userId", "userName", "confidence", "timestamp", "companyId"]
    },
    "APIKey": {
      "title": "API Key",
      "description": "Credential for developers to access the AfriVerify API.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "key": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "REVOKED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "key", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/verifications/{verificationId}": {
      "schema": "#/backend/entities/Verification",
      "description": "Collection of identity verification records."
    },
    "/attendance/{attendanceId}": {
      "schema": "#/backend/entities/AttendanceRecord",
      "description": "Collection of employee check-in records."
    },
    "/apikeys/{keyId}": {
      "schema": "#/backend/entities/APIKey",
      "description": "Collection of developer API keys."
    }
  }
}
